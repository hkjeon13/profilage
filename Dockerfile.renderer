FROM mcr.microsoft.com/playwright/python:v1.54.0-noble

ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
WORKDIR /renderer
RUN pip install --no-cache-dir "cryptography>=45.0.0" "playwright==1.54.0" "redis>=5.0.0" "httpx>=0.27.0"
COPY app ./app
COPY renderer ./renderer
USER pwuser
CMD ["python", "renderer/worker.py"]
